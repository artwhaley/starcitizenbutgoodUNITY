* text=auto

# Unity text assets should stay diffable.
*.asmdef text
*.asset text
*.controller text
*.inputactions text
*.mat text
*.meta text
*.overrideController text
*.playable text
*.prefab text
*.shader text
*.unity text

# Binary art/audio/model data belongs in Git LFS.
*.3dm filter=lfs diff=lfs merge=lfs -text
*.3ds filter=lfs diff=lfs merge=lfs -text
